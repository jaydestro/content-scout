# Content Scout API Keys
# Copy this file to .env and fill in your keys.
# The .env file is gitignored — never commit secrets.

# YouTube Data API v3 key (free) — enables YouTube community video scanning
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Bluesky credentials (free) — enables Bluesky mention and hashtag tracking
# Create an app password at: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# X/Twitter Bearer Token — enables X conversation and mention tracking
# Requires $200/mo Basic plan: https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=
