# Content Scout API Keys
# Copy this file to .env and fill in your keys.
# The .env file is gitignored — never commit secrets.

# Reddit OAuth2 credentials (free, OPTIONAL) — only useful if Reddit approved your app.
# Without these, Content Scout uses the layered no-auth Reddit scanner:
#   Layer 1: old.reddit.com RSS → Layer 2: old.reddit.com HTML → Layer 3: Google PSE
#   → Layer 4: manual import via /scout-reddit-import
# Reddit's "Responsible Builder Policy" denies most new app registrations — leave these blank if you got denied.
# Register an app at: https://www.reddit.com/prefs/apps/  (or https://old.reddit.com/prefs/apps/)
# Choose "script" type, set redirect URI to http://localhost:8080
# REDDIT_USER_AGENT format: content-scout/1.0 by <your-reddit-username>
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Google Programmable Search Engine (free, OPTIONAL) — enables Reddit Layer 3.
# Catches Reddit threads in subreddits you didn't list. 100 free queries/day.
# 1. Get an API key at https://console.cloud.google.com/apis/credentials (Custom Search API)
# 2. Create a Programmable Search Engine at https://programmablesearchengine.google.com/
#    — set "Sites to search" to `reddit.com/*` and copy the Search engine ID.
GOOGLE_PSE_KEY=
GOOGLE_PSE_CX=

# Bluesky credentials (free) — enables Bluesky mention and hashtag tracking
# Create an app password at: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# X/Twitter Bearer Token — enables X conversation and mention tracking
# Requires $200/mo Basic plan for reliable results: https://developer.x.com/en/portal/dashboard
# Without this, X scanning attempts best-effort public search (may be incomplete or unavailable).
X_BEARER_TOKEN=

# Optional: Add YouTube or any other API keys as custom rows in the Setup UI.
# YouTube Data API v3 key (free): https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=

# Optional: GitHub token (raises unauth rate limit from 60/hr to 5000/hr).
# Create a fine-grained token with public-repo read at https://github.com/settings/tokens
# GITHUB_TOKEN=

# Optional: Webhook URL — Content Scout POSTs a JSON summary here at end of every scan.
# Use a Slack/Teams/Discord/Zapier incoming webhook. On non-2xx the run continues; failure is logged.
# SCOUT_WEBHOOK_URL=

# --- Vision provider (for /scout-alt image inspection) -----------------------
# Pick one of: none | ollama | openai | custom
# - none: agent must work from your typed description (or refuse if you also skip the description)
# - ollama: local, free, private. Requires Ollama running and a vision model pulled.
#     Install: https://ollama.com  →  ollama pull llama3.2-vision   (or moondream / llava)
# - openai: cloud, ~$0.0002/image with gpt-4o-mini. Requires OPENAI_API_KEY.
# - custom: any OpenAI-compatible /chat/completions endpoint with vision.
#     Works for Azure OpenAI, Azure AI Foundry Inference, OpenRouter, LM Studio,
#     vLLM, llama.cpp server, Together, Groq, Anyscale, etc.
# VISION_PROVIDER=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_VISION_MODEL=llama3.2-vision
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# CUSTOM_VISION_BASE_URL=
# CUSTOM_VISION_API_KEY=
# CUSTOM_VISION_MODEL=
# CUSTOM_VISION_AUTH_STYLE=bearer    # or "api-key" for Azure OpenAI
