# Content Scout API Keys
# Copy this file to .env and fill in your keys.
# The .env file is gitignored — never commit secrets.

# Reddit OAuth2 credentials (free, OPTIONAL) — only useful if Reddit approved your app.
# Without these, Content Scout uses the layered no-auth Reddit scanner:
#   Layer 1: old.reddit.com RSS → Layer 2: old.reddit.com HTML → Layer 3: Google PSE
#   → Layer 4: manual import via /scout-reddit-import
# Reddit's "Responsible Builder Policy" denies most new app registrations — leave these blank if you got denied.
# Register an app at: https://www.reddit.com/prefs/apps/  (or https://old.reddit.com/prefs/apps/)
# Choose "script" type, set redirect URI to http://localhost:8080
# REDDIT_USER_AGENT format: content-scout/1.0 by <your-reddit-username>
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Brave Search API (free tier: 2,000 queries/month, 1 query/second) — RECOMMENDED.
# Enables free public-web discovery for Reddit (Layer 3), LinkedIn, and X/Twitter
# from a single key. Brave indexes the public web independently of Google.
# Sign up at https://brave.com/search/api/ — the "Free AI" or "Data for Search"
# plan grants 2k queries/month at $0 (no card required). Manage keys at:
# https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# Google Programmable Search Engine (LEGACY — closed to new customers since
# early 2026; existing customers supported through Jan 1, 2027). Skip this
# unless you already had a working PSE on a pre-2026 GCP project. New projects
# get a permanent 403 "This project does not have the access to Custom Search
# JSON API" no matter what you configure. Use BRAVE_SEARCH_API_KEY above instead.
# Docs: https://developers.google.com/custom-search/v1/overview
GOOGLE_PSE_KEY=
GOOGLE_PSE_CX=

# Bluesky credentials (free) — enables Bluesky mention and hashtag tracking
# Create an app password at: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# X/Twitter Bearer Token (OPTIONAL) — enables authenticated X search.
# X's Free tier blocks most read endpoints; the $200/mo Basic plan is needed
# for reliable API access. As a free alternative, set BRAVE_SEARCH_API_KEY above
# and/or add RSSHub feeds under `## Custom RSS Feeds` in your config (e.g.
# https://rsshub.app/twitter/user/<handle>).
X_BEARER_TOKEN=

# Optional: Add YouTube or any other API keys as custom rows in the Setup UI.
# YouTube Data API v3 key (free): https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=

# Optional: GitHub token (raises unauth rate limit from 60/hr to 5000/hr).
# Create a fine-grained token with public-repo read at https://github.com/settings/tokens
# GITHUB_TOKEN=

# Optional: Webhook URL — Content Scout POSTs a JSON summary here at end of every scan.
# Use a Slack/Teams/Discord/Zapier incoming webhook. On non-2xx the run continues; failure is logged.
# SCOUT_WEBHOOK_URL=

# --- Vision provider (for /scout-alt image inspection) -----------------------
# Pick one of: none | ollama | openai | custom
# - none: agent must work from your typed description (or refuse if you also skip the description)
# - ollama: local, free, private. Requires Ollama running and a vision model pulled.
#     Install: https://ollama.com  →  ollama pull llama3.2-vision   (or moondream / llava)
# - openai: cloud, ~$0.0002/image with gpt-4o-mini. Requires OPENAI_API_KEY.
# - custom: any OpenAI-compatible /chat/completions endpoint with vision.
#     Works for Azure OpenAI, Azure AI Foundry Inference, OpenRouter, LM Studio,
#     vLLM, llama.cpp server, Together, Groq, Anyscale, etc.
# VISION_PROVIDER=
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_VISION_MODEL=llama3.2-vision
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# CUSTOM_VISION_BASE_URL=
# CUSTOM_VISION_API_KEY=
# CUSTOM_VISION_MODEL=
# CUSTOM_VISION_AUTH_STYLE=bearer    # or "api-key" for Azure OpenAI

# --- Sentiment reviewer (Conversations triage "🤖 Re-check" button) ---
# Second opinion on the sentiment classification of a conversation row.
# DEFAULTS TO `agent` — reuses the same CLI agent runner you configured
# for /scout-scan (Claude Code, Copilot CLI, Codex, Gemini CLI, etc.),
# so no extra install / no extra keys are needed. Set
# SENTIMENT_PROVIDER=none to disable the button entirely.
# - agent:  (default) spawn the configured /scout-scan runner. Slowest
#           but uses the same model you trust for everything else.
# - ollama: local + free. Reuses OLLAMA_HOST. Default model: llama3.1:8b
#           (try llama3.2:3b or qwen2.5:3b for faster turnaround).
#           Install: ollama pull llama3.1:8b
# - openai: cloud, gpt-4o-mini by default. Reuses OPENAI_API_KEY.
# - custom: any OpenAI-compatible /chat/completions endpoint.
# SENTIMENT_PROVIDER=agent
# SENTIMENT_AGENT_TIMEOUT_MS=180000   # raise if Copilot CLI / Claude Code cold-starts slowly
# OLLAMA_SENTIMENT_MODEL=llama3.1:8b
# OPENAI_SENTIMENT_MODEL=gpt-4o-mini
# CUSTOM_SENTIMENT_BASE_URL=
# CUSTOM_SENTIMENT_API_KEY=
# CUSTOM_SENTIMENT_MODEL=
# CUSTOM_SENTIMENT_AUTH_STYLE=bearer    # or "api-key" for Azure OpenAI
