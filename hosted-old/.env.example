# Content Scout — Hosted Agent environment template
# ---------------------------------------------------
# Copy this file to `.env` for local development. For production, nothing in
# this file is read directly by the agent — values are either:
#   - Provisioned by `azd up` (Foundry endpoint, model deployment, storage, KV)
#   - Loaded at runtime from Azure Key Vault via Managed Identity (API keys)
#
# So in production you typically only need to run `azd up` once. Locally, set
# AZURE_* values to the outputs of your azd deployment and your DefaultAzureCredential
# (e.g. `az login`) will authenticate against them.

# ---------------------------------------------------------------------------
# Foundry project + model deployment
# ---------------------------------------------------------------------------
# Set automatically by `azd up` from infra/main.bicep outputs.
AZURE_AI_PROJECT_ENDPOINT=https://aif-<env>-<token>.services.ai.azure.com/api/projects/content-scout-project
AZURE_AI_FOUNDRY_ENDPOINT=https://aif-<env>-<token>.cognitiveservices.azure.com/

# Which LLM to use for social-post drafting, sentiment, trend narratives.
# Must match the name of a deployment in your Foundry project.
# Recommended:
#   - gpt-4o-mini  → cheap + fast (default, provisioned by azd up)
#   - gpt-4o       → higher quality reasoning for trends/gaps
#   - gpt-5-mini   → newer alternative if available in your region
# Change MODEL_NAME in azd env to swap what's provisioned:
#   azd env set MODEL_NAME gpt-4o
#   azd env set MODEL_VERSION 2024-11-20
#   azd up
MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ---------------------------------------------------------------------------
# Azure infrastructure (all provisioned by `azd up`)
# ---------------------------------------------------------------------------
# Managed Identity — used for ALL Azure auth (Foundry, Key Vault, Storage, ACR)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# Key Vault — scanner API keys are loaded from here at agent startup.
AZURE_KEY_VAULT_NAME=
AZURE_KEY_VAULT_ENDPOINT=

# Blob Storage — reports, social posts, and dedup tracker persist here.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_BLOB_ENDPOINT=

# ---------------------------------------------------------------------------
# Agent behavior
# ---------------------------------------------------------------------------
SCOUT_CONFIG_PATH=.github/prompts/

# ---------------------------------------------------------------------------
# Scanner API keys — LOCAL DEV ONLY
# ---------------------------------------------------------------------------
# In production these are stored in Key Vault as:
#   youtube-api-key, reddit-client-id, reddit-client-secret,
#   bluesky-handle, bluesky-app-password, x-bearer-token
# Upload them after `azd up`:
#   az keyvault secret set --vault-name $AZURE_KEY_VAULT_NAME --name youtube-api-key --value '<key>'
# The agent auto-loads them on boot. See docs/HOSTED-AGENT.md for the full flow.

YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
X_BEARER_TOKEN=
