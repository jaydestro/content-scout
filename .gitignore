# ---------------------------------------------------------------------------
# Secrets & API keys — NEVER commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env.local
*.pem
*.key
*.pfx
*.crt
credentials.json
secrets.json

# Seen-links tracker (local state, not shared)
reports/.seen-links.json

# Persistent ecosystem state (creators.json etc — local state, not shared)
# Note: reports/.scout-state.shared/ is intentionally NOT ignored — teams
# can opt into committed shared state by setting `shared_state: true` in
# their config and committing reports/.scout-state.shared/ to the repo.
reports/.scout-state/

# Product configs contain product-specific settings and occasionally API
# references — do not commit. Use scout-config-example.prompt.md as a template.
.github/prompts/scout-config-*.prompt.md
!.github/prompts/scout-config-example.prompt.md

# Generated content reports (internal — not shared)
reports/*.md
!reports/README.md

# Generated social posts and posting calendars (internal — not shared)
social-posts/*.md
!social-posts/README.md

# Generated thumbnails / images (keep brand assets folder)
social-posts/images/*
!social-posts/images/brand/

# ---------------------------------------------------------------------------
# Node.js / npm (covers all tools/* packages)
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
.pnp.*
*.tgz

# Web UI local settings
**/.scout-web-settings.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing & coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Azure Developer CLI (azd)
# ---------------------------------------------------------------------------
.azure/
azd-env-*.json

# ---------------------------------------------------------------------------
# Bicep / Terraform build artifacts
# ---------------------------------------------------------------------------
*.bicep.json
infra/**/main.json
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Docker build artifacts
# ---------------------------------------------------------------------------
*.tar
docker-compose.override.yml

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
# VS Code — keep only shared settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# Cursor — keep shared rules
.cursor/*
!.cursor/rules/

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# Sublime
*.sublime-workspace

# ---------------------------------------------------------------------------
# Logs & scratch
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
scratch/
