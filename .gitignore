# ---------------------------------------------------------------------------
# Secrets & API keys — NEVER commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env.local
*.pem
*.key
*.pfx
*.crt
credentials.json
secrets.json

# OAuth client secret JSON files downloaded from Google Cloud, Azure
# portal, etc. — file names typically include the client id / project id,
# so glob on the obvious prefixes regardless of where they land.
client_secret*.json
*-client-secret.json
*.client_secret.json

# AWS / Azure / GCP credential dumps that sometimes get accidentally
# saved to a project root.
.aws/credentials
.azure/credentials
.gcp/credentials.json
service-account*.json
*-service-account.json

# ---------------------------------------------------------------------------
# Scratch / diagnostic / one-off files (any folder)
# ---------------------------------------------------------------------------
# Anything prefixed with `_` or `scratch-` or matching common scratch
# patterns is treated as throwaway local work. Diagnostic dumps from the
# browser-scan tool (e.g. linkedin-diag.json, *-first-result.html) follow
# the same rule. Hidden-file variants (`.scratch-*`) are also covered so
# files like `tools/.scratch-1525-build.py` don't sneak in.
scratch/
scratch-*
*.scratch
*.scratch.*
*-scratch.*
.scratch/
.scratch-*
**/.scratch/
**/.scratch-*
_scratch/
**/_scratch/
.tmp/
**/.tmp/
diag-*
*-diag.*
*-first-result.html
*-first-result.json
*.tmp
*.bak
*.orig
*.local.*

# Seen-links tracker (local state, not shared)
reports/.seen-links.json
reports/.seen-urls-cache.txt

# Persistent ecosystem state (creators.json etc — local state, not shared)
# Note: reports/.scout-state.shared/ is intentionally NOT ignored — teams
# can opt into committed shared state by setting `shared_state: true` in
# their config and committing reports/.scout-state.shared/ to the repo.
reports/.scout-state/

# Browser-scan sidecars (local-only scrape output that scout scan ingests
# as Layer 0 for X / LinkedIn / Reddit). Keep them off the wire — they
# contain logged-in scrape data and personal handles.
reports/.browser-scan/

# Per-run scan prompts archive. Every time `scout scan` is invoked via a
# subagent, the resolved prompt (with the run stamp, sidecar paths, and
# context) is saved here for audit / replay / diff. Local-only.
reports/.scan-prompts/

# Browser-scan persistent Edge profile — contains live session cookies
# for X, LinkedIn, and Reddit. NEVER commit.
tools/browser-scan/.profile/

# Browser-scan dedicated CDP profile (used by `node index.mjs launch` so
# the user's day-to-day Edge profile is left alone). Also contains live
# session cookies — NEVER commit.
tools/browser-scan/.cdp-profile/

# Product configs contain product-specific settings and occasionally API
# references — do not commit. Use scout-config-example.prompt.md as a template.
.github/prompts/scout-config-*.prompt.md
!.github/prompts/scout-config-example.prompt.md

# Generated content reports (internal — not shared)
reports/*.md
!reports/README.md
reports/*.json
!reports/.scout-state.shared/**/*.json

# Generated social posts and posting calendars (internal — not shared)
social-posts/*.md
!social-posts/README.md
social-posts/*.json

# Generated thumbnails / images (keep brand assets folder)
social-posts/images/*
!social-posts/images/brand/

# Per-product brand assets are local customizations — never commit
social-posts/images/brand/azure-cosmos-db/

# ---------------------------------------------------------------------------
# Node.js / npm (covers all tools/* packages)
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
.pnp.*
*.tgz

# Web UI local settings
**/.scout-web-settings.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing & coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Azure Developer CLI (azd)
# ---------------------------------------------------------------------------
.azure/
azd-env-*.json

# ---------------------------------------------------------------------------
# Bicep / Terraform build artifacts
# ---------------------------------------------------------------------------
*.bicep.json
infra/**/main.json
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Docker build artifacts
# ---------------------------------------------------------------------------
*.tar
docker-compose.override.yml

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
# VS Code — keep only shared settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# Cursor — keep shared rules
.cursor/*
!.cursor/rules/

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# Sublime
*.sublime-workspace

# ---------------------------------------------------------------------------
# Logs & scratch
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
scratch/
